{
    "name": "freespoke\/wordpress",
    "type": "library",
    "repositories": [
        {
            "type": "path",
            "url": "..\/php",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.1",
        "freespoke\/partner": "^1.0 || dev-master"
    },
    "require-dev": {
        "phpunit\/phpunit": "^11.0 || ^12.0",
        "brain\/monkey": "^2.6",
        "mockery\/mockery": "^1.6"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Freespoke\\Wordpress\\": "src\/"
        },
        "files": [
            "src\/Aliases.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Freespoke\\Wordpress\\Tests\\": "tests\/"
        }
    },
    "authors": [
        {
            "name": "John Pedrie",
            "email": "john@freespoke.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}